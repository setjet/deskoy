{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/index.ts",
    "src/renderer.ts",
    "src/preload.ts",
    "src/cover/cover.ts",
    "forge.config.ts"
  ],
  "project": ["src/**/*.ts", "*.ts", "scripts/**/*.cjs"],
  "ignoreBinaries": [],
  "ignoreDependencies": [
    "webpack",
    "@electron-forge/shared-types",
    "@felixrieseberg/electron-forge-maker-nsis",
    "@vercel/webpack-asset-relocator-loader",
    "css-loader",
    "file-loader",
    "node-loader",
    "style-loader",
    "ts-loader"
  ],
  "ignoreIssues": {
    "forge.config.ts": ["exports"]
  }
}
