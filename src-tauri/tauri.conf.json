{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Deskoy",
  "version": "1.3.0",
  "identifier": "com.deskoy.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Deskoy",
        "width": 900,
        "height": 600,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "visible": true,
        "backgroundColor": "#111113"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "../assets/icon.ico",
      "../assets/icon.png"
    ],
    "resources": [
      "../assets/*",
      "../public/cover/*"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "nsis-hooks.nsh",
        "installerIcon": "../assets/icon.ico",
        "uninstallerIcon": "../assets/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQzRTBFMzk4QTVBMUM3ODUKUldTRng2R2xtT1BnUTlwRXY2Z3EyUTl6ZjlJcThiL3FzbkxsaWNibDljWUsxSzVSbE5tZyt3R3IK",
      "endpoints": [
        "https://github.com/deskoys/deskoy/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
